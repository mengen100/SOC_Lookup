{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EventPageRecord",
  "description": "单个Windows Security或Sysmon事件详情页的数据结构",
  "type": "object",
  "required": [
    "id",
    "source",
    "category",
    "name",
    "priority",
    "applicable_version",
    "last_reviewed",
    "definition",
    "trigger_scenarios",
    "key_fields",
    "false_positives",
    "related_event_ids",
    "detection_notes",
    "sample_log",
    "source_url"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "事件ID，如 '4625' 或 '1'"
    },
    "source": {
      "type": "string",
      "enum": ["windows_security", "sysmon"]
    },
    "category": {
      "type": "string",
      "description": "功能分类，如 Logon、Process、Registry等，用于导航筛选"
    },
    "name": {
      "type": "string",
      "description": "官方事件名称"
    },
    "priority": {
      "type": "string",
      "enum": ["P1", "P2", "P3"]
    },
    "applicable_version": {
      "type": "string",
      "description": "适用的Windows/Sysmon版本范围"
    },
    "last_reviewed": {
      "type": "string",
      "format": "date",
      "description": "本页内容最后核对日期，ISO 8601格式"
    },
    "definition": {
      "type": "string",
      "description": "一句话定义"
    },
    "trigger_scenarios": {
      "type": "string",
      "description": "触发场景说明"
    },
    "key_fields": {
      "type": "array",
      "description": "关键日志字段解读",
      "items": {
        "type": "object",
        "required": ["field", "explanation"],
        "properties": {
          "field": { "type": "string" },
          "explanation": { "type": "string" }
        }
      }
    },
    "false_positives": {
      "type": "array",
      "description": "常见误报场景列表",
      "items": { "type": "string" }
    },
    "related_event_ids": {
      "type": "array",
      "description": "关联事件ID列表，用于内部互链",
      "items": { "type": "string" }
    },
    "attck_mapping": {
      "type": "array",
      "description": "MITRE ATT&CK技术映射，如无可靠关联可留空数组",
      "items": {
        "type": "object",
        "required": ["technique_id", "technique_name"],
        "properties": {
          "technique_id": { "type": "string", "description": "如 T1110.003" },
          "technique_name": { "type": "string" }
        }
      }
    },
    "detection_notes": {
      "type": "string",
      "description": "检测与排查建议，体现专业判断的核心字段"
    },
    "kql_snippet": {
      "type": "string",
      "description": "Microsoft Sentinel KQL查询示例，可选"
    },
    "spl_snippet": {
      "type": "string",
      "description": "Splunk SPL查询示例，可选"
    },
    "sample_log": {
      "type": "string",
      "description": "脱敏后的示例日志文本"
    },
    "source_url": {
      "type": "string",
      "format": "uri",
      "description": "官方文档出处链接"
    }
  }
}
