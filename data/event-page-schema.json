{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EventPageRecord",
  "description": "Data structure for a single Windows Security or Sysmon event detail page.",
  "type": "object",
  "required": [
    "id",
    "source",
    "category",
    "name",
    "priority",
    "applicable_version",
    "last_reviewed",
    "definition",
    "trigger_scenarios",
    "key_fields",
    "false_positives",
    "related_event_ids",
    "detection_notes",
    "sample_log",
    "source_url"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Event ID, such as '4625' or '1'."
    },
    "source": {
      "type": "string",
      "enum": [
        "windows_security",
        "sysmon"
      ]
    },
    "category": {
      "type": "string",
      "description": "Functional category such as Logon, Process, or Registry, used for navigation filters."
    },
    "name": {
      "type": "string",
      "description": "Official event name."
    },
    "priority": {
      "type": "string",
      "enum": [
        "P1",
        "P2",
        "P3"
      ]
    },
    "applicable_version": {
      "type": "string",
      "description": "Applicable Windows or Sysmon version range."
    },
    "last_reviewed": {
      "type": "string",
      "format": "date",
      "description": "Date this page content was last reviewed, in ISO 8601 format."
    },
    "definition": {
      "type": "string",
      "description": "One-sentence event definition."
    },
    "trigger_scenarios": {
      "type": "string",
      "description": "Explanation of scenarios that trigger the event."
    },
    "key_fields": {
      "type": "array",
      "description": "Key log fields and how analysts should interpret them.",
      "items": {
        "type": "object",
        "required": [
          "field",
          "explanation"
        ],
        "properties": {
          "field": {
            "type": "string"
          },
          "explanation": {
            "type": "string"
          }
        }
      }
    },
    "false_positives": {
      "type": "array",
      "description": "List of common false-positive scenarios.",
      "items": {
        "type": "string"
      }
    },
    "related_event_ids": {
      "type": "array",
      "description": "Related event IDs for internal pivots.",
      "items": {
        "type": "string"
      }
    },
    "attck_mapping": {
      "type": "array",
      "description": "MITRE ATT&CK technique mapping; use an empty array when there is no reliable mapping.",
      "items": {
        "type": "object",
        "required": [
          "technique_id",
          "technique_name"
        ],
        "properties": {
          "technique_id": {
            "type": "string",
            "description": "Example: T1110.003."
          },
          "technique_name": {
            "type": "string"
          }
        }
      }
    },
    "detection_notes": {
      "type": "string",
      "description": "Detection and investigation guidance; this is the core field for analyst judgment."
    },
    "kql_snippet": {
      "type": "string",
      "description": "Optional Microsoft Sentinel KQL query example."
    },
    "spl_snippet": {
      "type": "string",
      "description": "Optional Splunk SPL query example."
    },
    "sample_log": {
      "type": "string",
      "description": "Sanitized sample log text."
    },
    "source_url": {
      "type": "string",
      "format": "uri",
      "description": "Official documentation source URL."
    }
  }
}
