{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EventPageRecord",
  "description": "Data structure for a single Windows Security or Sysmon event detail page.",
  "type": "object",
  "required": [
    "id",
    "source",
    "category",
    "name",
    "priority",
    "applicable_version",
    "last_reviewed",
    "definition",
    "trigger_scenarios",
    "key_fields",
    "false_positives",
    "related_event_ids",
    "detection_notes",
    "sample_log",
    "source_url"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Event ID, such as '4625' or '1'."
    },
    "source": {
      "type": "string",
      "enum": [
        "windows_security",
        "sysmon"
      ]
    },
    "category": {
      "type": "string",
      "description": "Functional category such as Logon, Process, or Registry, used for navigation filters."
    },
    "name": {
      "type": "string",
      "description": "Official event name."
    },
    "priority": {
      "type": "string",
      "enum": [
        "P1",
        "P2",
        "P3"
      ]
    },
    "applicable_version": {
      "type": "string",
      "description": "Applicable Windows or Sysmon version range."
    },
    "last_reviewed": {
      "type": "string",
      "format": "date",
      "description": "Date this page content was last reviewed, in ISO 8601 format."
    },
    "definition": {
      "type": "string",
      "description": "One-sentence event definition."
    },
    "trigger_scenarios": {
      "type": "string",
      "description": "Explanation of scenarios that trigger the event."
    },
    "key_fields": {
      "type": "array",
      "description": "Key log fields and how analysts should interpret them.",
      "items": {
        "type": "object",
        "required": [
          "field",
          "explanation"
        ],
        "properties": {
          "field": {
            "type": "string"
          },
          "explanation": {
            "type": "string"
          }
        }
      }
    },
    "false_positives": {
      "type": "array",
      "description": "List of common false-positive scenarios.",
      "items": {
        "type": "string"
      }
    },
    "related_event_ids": {
      "type": "array",
      "description": "Related event IDs for internal pivots.",
      "items": {
        "type": "string"
      }
    },
    "attck_mapping": {
      "type": "array",
      "description": "MITRE ATT&CK technique mapping; use an empty array when there is no reliable mapping.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "technique_id",
          "technique_name"
        ],
        "properties": {
          "tactic_id": {
            "type": "string",
            "pattern": "^TA[0-9]{4}$"
          },
          "tactic_name": {
            "type": "string",
            "minLength": 1
          },
          "technique_id": {
            "type": "string",
            "pattern": "^T[0-9]{4}(\\.[0-9]{3})?$",
            "description": "Example: T1110.003."
          },
          "technique_name": {
            "type": "string",
            "minLength": 1
          },
          "source_url": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    },
    "technical_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "channel",
        "level"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "channel": {
          "type": "string",
          "minLength": 1
        },
        "level": {
          "type": "string",
          "minLength": 1
        },
        "audit_keyword": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "queries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "language",
          "title",
          "query",
          "data_source",
          "assumptions"
        ],
        "properties": {
          "language": {
            "type": "string",
            "enum": [
              "kql",
              "spl",
              "xql",
              "sigma"
            ]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "query": {
            "type": "string",
            "minLength": 1
          },
          "data_source": {
            "type": "string",
            "minLength": 1
          },
          "assumptions": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "source_url": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    },
    "value_references": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "field",
          "value",
          "meaning",
          "security_relevance",
          "source_url"
        ],
        "properties": {
          "field": {
            "type": "string",
            "minLength": 1
          },
          "value": {
            "type": "string",
            "minLength": 1
          },
          "meaning": {
            "type": "string",
            "minLength": 1
          },
          "security_relevance": {
            "type": "string",
            "minLength": 1
          },
          "source_url": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    },
    "faqs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "question",
          "answer"
        ],
        "properties": {
          "question": {
            "type": "string",
            "minLength": 1
          },
          "answer": {
            "type": "string"
          }
        }
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title",
          "url",
          "publisher",
          "source_type"
        ],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "publisher": {
            "type": "string",
            "minLength": 1
          },
          "source_type": {
            "type": "string",
            "enum": [
              "vendor",
              "attack",
              "detection-rule"
            ]
          }
        }
      }
    },
    "detection_notes": {
      "type": "string",
      "description": "Detection and investigation guidance; this is the core field for analyst judgment."
    },
    "kql_snippet": {
      "type": "string",
      "description": "Optional Microsoft Sentinel KQL query example."
    },
    "spl_snippet": {
      "type": "string",
      "description": "Optional Splunk SPL query example."
    },
    "sample_log": {
      "type": "string",
      "description": "Sanitized sample log text."
    },
    "source_url": {
      "type": "string",
      "format": "uri",
      "description": "Official documentation source URL."
    }
  }
}
